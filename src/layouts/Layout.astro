---
import Navbar from '@/components/Navbar/navbar';
import ButtonCV_Theme from '@/components/buttonCV';
import ThemeToggler from '@/components/themeButton';
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Adrián. — Desarrollador Full Stack",
  description = "Portfolio de desarrollo full stack y diseño digital.",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;900&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (function () {
        const saved = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const isDark = saved ? saved === "dark" : prefersDark;
        document.documentElement.classList.toggle("dark", isDark);
      })();
    </script>
  </head>

  <body class="bg-[#0A0A0A] text-white font-sans antialiased min-h-screen">

    <!-- ── NAVBAR ────────────────────────────────────────── -->
    <header
      id="navbar"
      class="fixed top-0 left-0 right-0 z-50 transition-all duration-300"
    >
      <div class="w-full px-6 lg:px-10 h-16 flex items-center justify-between">

        <!-- Logo -->
        <a
          href="/"
          class="font-display font-black text-xl text-white tracking-tight uppercase shrink-0"
        >
          Adrián<span class="text-[#C8FF00]">.</span>
        </a>

        <!-- Nav links (React island) -->
        <Navbar client:load textColor="white" />

        <!-- Acciones derecha -->
        <div class="flex items-center gap-3 shrink-0">
          <ThemeToggler client:load />
          <ButtonCV_Theme />
        </div>

      </div> 
    </header>

    <!-- ── CONTENIDO ─────────────────────────────────────── -->
    <main>
      <slot />
    </main>

    <!-- ── FOOTER ────────────────────────────────────────── -->
    <footer class="border-t border-[#1A1A1A] py-10">
      <div class="max-w-7xl mx-auto px-6 lg:px-10 flex flex-col sm:flex-row items-center justify-between gap-4">
        <span class="font-display font-black text-lg text-white uppercase">
          Adrián<span class="text-[#C8FF00]">.</span>
        </span>
        <p class="text-[#555555] text-sm font-mono">
          © {new Date().getFullYear()} 
        </p>
        <div class="flex items-center gap-5">
          <a href="https://github.com/adrian9906" target="_blank" rel="noopener" class="text-[#A0A0A0] hover:text-[#C8FF00] transition-colors duration-200">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.014-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
          </a>
          <a href="https://www.linkedin.com/in/adrian-d-fernandez-12096b297/" target="_blank" rel="noopener" class="text-[#A0A0A0] hover:text-[#C8FF00] transition-colors duration-200">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="mailto:adriandfl99@gmail.com" class="text-[#A0A0A0] hover:text-[#C8FF00] transition-colors duration-200">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </a>
        </div>
      </div>
    </footer>

  </body>
</html>

<!-- ── NAVBAR SCROLL BEHAVIOR ────────────────────────────── -->
<script>
  const navbar = document.getElementById("navbar");

  const updateNavbar = () => {
    if (window.scrollY > 20) {
      navbar?.classList.add(
        "bg-[#0A0A0A]/70",
        "backdrop-blur-xl",
        "border-b",
        "border-[#1A1A1A]"
      );
      navbar?.classList.remove("bg-transparent");
    } else {
      navbar?.classList.remove(
        "bg-[#0A0A0A]/70",
        "backdrop-blur-xl",
        "border-b",
        "border-[#1A1A1A]"
      );
      navbar?.classList.add("bg-transparent");
    }
  };

  updateNavbar();
  window.addEventListener("scroll", updateNavbar, { passive: true });
</script>

<style is:global>
  /* View Transitions para el theme toggler animado */
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }

  .dark::view-transition-old(root) { z-index: 1; }
  .dark::view-transition-new(root) { z-index: 999; }
  ::view-transition-old(root)      { z-index: 999; }
  ::view-transition-new(root)      { z-index: 1; }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #0A0A0A; }
  ::-webkit-scrollbar-thumb { background: #1A1A1A; border-radius: 999px; }
  ::-webkit-scrollbar-thumb:hover { background: #C8FF00; }

  /* Selección */
  ::selection { background: #C8FF00; color: #0A0A0A; }
</style>